// Account model (planning): there is no User/UserRole in this schema yet.
// Future auth on THIS website should be PATIENT | ADMIN only.
// The Doctor model below is public marketing/directory data — not a login identity.
// Clinical doctor accounts belong to a separate doctor portal (deferred, out of scope).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LocaleCode {
  EN
  PT
  ES
  CS
  RO
  DE
}

enum AssetKind {
  IMAGE
  ICON
  LOGO
  BADGE
  SOCIAL
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

enum ServiceKind {
  GENERAL
  SPECIALIST
  PRESCRIPTION
  HEALTH_TEST
  HOME_DELIVERY
}

enum UserRole {
  PATIENT
  ADMIN
  /// Clinician account — logs in to /doctor and sees only their own
  /// patients + appointments. Linked to a Doctor profile via
  /// `User.doctorId` (one-to-one).
  DOCTOR
}

enum PageKey {
  HOME
  GENERAL_CONSULTATION
  SPECIALIST_CONSULTATION
  DOCTORS_INDEX
  PRESCRIPTIONS
  HEALTH_TESTS
}

/// Lifecycle for a concrete bookable slot on a doctor's calendar.
///   OPEN     — published, can be claimed by a booking
///   HELD     — temporarily reserved (e.g. patient in checkout)
///   BOOKED   — claimed by an Appointment row
///   BLOCKED  — admin/doctor marked it unavailable (vacation, sick day, training)
enum DoctorSlotStatus {
  OPEN
  HELD
  BOOKED
  BLOCKED
}

/// Clinical consultation lifecycle.
///   DRAFT  — doctor is still editing
///   SIGNED — locked; further edits require a new amendment (out of scope)
enum ConsultationStatus {
  DRAFT
  SIGNED
}

/// Author side for internal (doctor ↔ admin) per-appointment notes. Kept
/// separate from the patient-facing `MessageAuthorRole` so we never mix
/// the two threads.
enum InternalMessageAuthorRole {
  DOCTOR
  ADMIN
}

/// Doctor portal notification kinds. Add new values here as we wire
/// more trigger points; the payload Json field carries the per-event
/// context (appointmentId, internalMessageId, etc.).
enum NotificationType {
  APPOINTMENT_ASSIGNED
  APPOINTMENT_STATUS_CHANGED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_FOLLOWUP_BOOKED
  APPOINTMENT_REMINDER
  INTERNAL_MESSAGE
  CONSULT_SIGNED
  EXAM_LOGGED
  EXAM_REQUESTED
  FORM_SUBMITTED
  DOCUMENT_UPLOADED
}

/// Exam lifecycle.
///   REQUESTED — doctor wants this test run; result hasn't been logged yet
///   COMPLETED — result has been recorded (notes / externalUrl)
enum ExamStatus {
  REQUESTED
  COMPLETED
}

/// Scope for a `ShareLink` token. CONSULTATION = doctor sharing a
/// signed consult with a referring colleague via signed URL.
enum ShareLinkScope {
  CONSULTATION
}

/// Mode an appointment is delivered in. The booking flow defaults to
/// ONLINE (the public site is a telemedicine platform); IN_PERSON is
/// supported for hybrid clinics where the doctor sees the patient
/// physically and the meetingUrl stays empty.
enum ConsultationMode {
  ONLINE
  IN_PERSON
}

/// Audit-log event kinds. Append-only; never repurpose a value. Add
/// new ones at the end. The list deliberately mixes clinical
/// mutations (CONSULT_*, EXAM_*) with collaboration events
/// (INTERNAL_MESSAGE_POSTED, SHARE_LINK_*) so a single admin view
/// can render the full handover trail per appointment.
enum AuditAction {
  CONSULT_SAVED
  CONSULT_SIGNED
  EXAM_LOGGED
  EXAM_DELETED
  INTERNAL_MESSAGE_POSTED
  SHARE_LINK_CREATED
  SHARE_LINK_REVOKED
  FORM_SUBMITTED
  CONSULT_SERVICE_ADDED
  CONSULT_SERVICE_REMOVED
  APPOINTMENT_STATUS_CHANGED
  APPOINTMENT_RESCHEDULED
  FOLLOW_UP_CREATED
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  DOCTOR_INVITED
  DOCTOR_CREATED
  DOCTOR_UPDATED
  DOCTOR_DEACTIVATED
  DOCTOR_PURGED
  DOCTOR_PHOTO_UPDATED
  DOCTOR_PHOTO_REMOVED
  APPOINTMENT_CREATED
  APPOINTMENT_PAYMENT_UPDATED
  TIMESLOT_RELEASED
}

model Currency {
  id        String    @id @default(cuid())
  code      String    @unique
  symbol    String
  decimals  Int       @default(2)
  countries Country[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Country {
  id                         String               @id @default(cuid())
  code                       String               @unique
  name                       String
  slug                       String               @unique
  legacyHomePath             String               @unique
  teamPath                   String               @unique
  generalConsultationPath    String               @unique
  specialistConsultationPath String               @unique
  defaultLocale              LocaleCode           @default(EN)
  currencyId                 String
  currency                   Currency             @relation(fields: [currencyId], references: [id])
  isActive                   Boolean              @default(true)
  countryLocales             CountryLocale[]
  domains                    CountryDomain[]
  clinics                    Clinic[]
  doctors                    Doctor[]
  /// Doctors with their *primary* country elsewhere who have been linked
  /// into this country's roster via the `DoctorCountry` M:N join.
  linkedDoctors              DoctorCountry[]
  specialties                Specialty[]
  services                   Service[]
  healthTests                HealthTest[]
  pricingPlans               PricingPlan[]
  assets                     Asset[]
  blogPosts                  BlogPost[]
  faqs                       Faq[]
  contentPages               ContentPage[]
  badges                     Badge[]
  reviews                    Review[]
  consultationSetting        ConsultationSetting?
  bookingSetting             BookingSetting?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
}

model CountryLocale {
  id        String     @id @default(cuid())
  countryId String
  locale    LocaleCode
  isDefault Boolean    @default(false)
  country   Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, locale])
}

model CountryDomain {
  id        String  @id @default(cuid())
  countryId String
  domain    String  @unique
  isPrimary Boolean @default(false)
  country   Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, isPrimary])
}

model Clinic {
  id        String   @id @default(cuid())
  countryId String
  name      String
  slug      String
  city      String?
  active    Boolean  @default(true)
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, slug])
}

/// Public website profile (directory/CMS) AND the target of a clinician
/// login when `User.doctorId` is set. The doctor portal at /doctor reads
/// `user.doctorProfile` to scope queries to this row's id.
model Doctor {
  id                     String                @id @default(cuid())
  countryId              String
  slug                   String
  fullName               String
  title                  String
  bio                    String?
  seoTitle               String?
  seoDescription         String?
  imcRegistration        String?
  medicalRegistrationUrl String?
  qualifications         String[]
  whatsappNumber         String?
  languages              String[]
  editorialChecklist     Json?
  active                 Boolean               @default(true)
  country                Country               @relation(fields: [countryId], references: [id], onDelete: Cascade)
  specialties            DoctorSpecialty[]
  assets                 Asset[]
  /// Additional country listings (Doctor ↔ Country M:N). The primary
  /// country still lives on `countryId` above and scopes slug uniqueness;
  /// each row here adds the doctor to another country's public roster.
  additionalCountries    DoctorCountry[]
  /// Inverse of `User.doctorId`. When set, that User logs in as this doctor.
  loginUser              User?                 @relation("DoctorUserLink")
  /// Inverse of `Appointment.doctorId`. Populated when admin assigns
  /// the doctor on the scheduling form.
  appointments           Appointment[]         @relation("AppointmentDoctor")
  /// Recurring weekly windows the doctor publishes for patient booking.
  /// Concrete slots are derived from these into `DoctorTimeSlot` rows.
  availabilities         DoctorAvailability[]
  /// Generated bookable slots. Booking flow claims one atomically.
  timeSlots              DoctorTimeSlot[]
  /// Inverse of `Consultation.doctorId`. Populated when the doctor
  /// starts a consult on one of their assigned appointments.
  consultations          Consultation[]
  /// Inverse of `ExamResult.doctorId`. Populated when the doctor
  /// uploads / records an exam result for an appointment.
  examResults            ExamResult[]
  /// Form templates this doctor owns. Templates with `doctorId = null`
  /// are shared/global (admin-managed).
  formTemplates          FormTemplate[]
  /// First-party documents the doctor has uploaded.
  appointmentDocuments   AppointmentDocument[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@unique([countryId, slug])
}

/// Doctor's recurring weekly availability window. One row = "every
/// {weekday} from {startMinute} until {endMinute} I take patients in
/// {slotDurationMinutes}-minute slots." Slot rows are derived from
/// these on-demand when the public availability endpoint is hit so the
/// site doesn't carry a year's worth of pre-generated rows for doctors
/// who don't get bookings.
model DoctorAvailability {
  id                  String    @id @default(cuid())
  doctorId            String
  /// 0 = Sunday … 6 = Saturday. Matches `Date#getDay()` in JS so the
  /// generation loop doesn't have to translate.
  weekday             Int
  /// Minute offset from midnight (LOCAL to the doctor's country timezone).
  /// e.g. 9 * 60 = 540 means 09:00; 17 * 60 = 1020 means 17:00.
  startMinute         Int
  endMinute           Int
  slotDurationMinutes Int       @default(30)
  /// Optional window boundaries — leave null for "always" availability.
  /// Useful for temporary schedules ("Tuesdays open from Sept 1 to Nov 30").
  effectiveFrom       DateTime?
  effectiveUntil      DateTime?
  isActive            Boolean   @default(true)
  doctor              Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([doctorId, weekday])
}

/// Concrete bookable slot derived from a doctor's availability windows.
/// `startAt`/`endAt` are stored as UTC; the generator translates from
/// the doctor's local timezone (Country.bookingSetting.timezone or a
/// sensible default per country).
///
/// `@@unique([doctorId, startAt])` is the atomic-claim contract: the
/// booking flow uses `UPDATE … WHERE id = ? AND status = 'OPEN'` to
/// flip it to `BOOKED` in one statement, preventing double-booking when
/// two patients hit submit at the same instant.
model DoctorTimeSlot {
  id          String           @id @default(cuid())
  doctorId    String
  startAt     DateTime
  endAt       DateTime
  status      DoctorSlotStatus @default(OPEN)
  /// Optional reason when status = BLOCKED. Free-text, admin-only.
  blockReason String?
  doctor      Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  /// One slot ↔ at most one appointment. Set via `Appointment.timeSlotId`.
  appointment Appointment?     @relation("AppointmentSlot")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([doctorId, startAt])
  @@index([doctorId, startAt, status])
}

/// Join row letting one Doctor profile appear on multiple country rosters.
/// The doctor's primary country lives on `Doctor.countryId`; this table is
/// for *additional* country listings only. We don't duplicate the primary
/// row here — public list queries UNION the primary + linked sets.
model DoctorCountry {
  id        String   @id @default(cuid())
  doctorId  String
  countryId String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([doctorId, countryId])
  @@index([countryId, active])
}

model Specialty {
  id               String            @id @default(cuid())
  countryId        String
  slug             String
  name             String
  cardSummary      String?
  cardThemeColor   String?
  sortOrder        Int               @default(0)
  primaryServiceId String?
  active           Boolean           @default(true)
  country          Country           @relation(fields: [countryId], references: [id], onDelete: Cascade)
  doctors          DoctorSpecialty[]
  services         Service[]         @relation("ServiceSpecialty")
  primaryService   Service?          @relation("SpecialtyPrimaryService", fields: [primaryServiceId], references: [id], onDelete: SetNull)
  assets           Asset[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([countryId, slug])
}

model DoctorSpecialty {
  id          String    @id @default(cuid())
  doctorId    String
  specialtyId String
  doctor      Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([doctorId, specialtyId])
}

model Service {
  id                    String                @id @default(cuid())
  countryId             String
  specialtyId           String?
  kind                  ServiceKind           @default(GENERAL)
  slug                  String
  name                  String
  summary               String?
  seoTitle              String?
  seoDescription        String?
  heroTitle             String?
  heroDescription       String?
  detailBody            String?
  ctaLabel              String?
  legacyPath            String?
  sortOrder             Int                   @default(0)
  durationMinutes       Int?
  basePriceCents        Int?
  currencyCode          String?
  editorialChecklist    Json?
  isActive              Boolean               @default(true)
  consultationSetting   Json?
  bookingSetting        Json?
  country               Country               @relation(fields: [countryId], references: [id], onDelete: Cascade)
  specialty             Specialty?            @relation("ServiceSpecialty", fields: [specialtyId], references: [id])
  primaryForSpecialties Specialty[]           @relation("SpecialtyPrimaryService")
  assets                Asset[]
  appointments          Appointment[]
  /// Per-consultation services-rendered line items. Doctor logs which
  /// catalogue services they performed during the consult; admin uses
  /// these for invoicing.
  consultationServices  ConsultationService[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([countryId, slug])
}

model PricingPlan {
  id           String   @id @default(cuid())
  countryId    String
  slug         String
  name         String
  description  String?
  priceCents   Int
  currencyCode String
  interval     String
  isActive     Boolean  @default(true)
  country      Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([countryId, slug])
}

model HealthTest {
  id                 String        @id @default(cuid())
  countryId          String
  slug               String
  title              String
  shortDescription   String?
  priceCents         Int
  currencyCode       String
  productImagePath   String
  galleryImagePaths  String[]
  sampleType         String?
  resultsTimeline    String?
  heroButtonLabel    String?
  detailIntro        String?
  whatThisTestCovers String[]
  whyGetTested       String[]
  extraSections      Json?
  sortOrder          Int           @default(0)
  isActive           Boolean       @default(true)
  seoTitle           String?
  seoDescription     String?
  legacyPath         String?
  country            Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  /// Appointments where the patient picked this specific health test
  /// at booking (`?service=<healthTestSlug>` matched a row here).
  appointments       Appointment[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([countryId, slug])
}

model Asset {
  id                  String        @id @default(cuid())
  countryId           String?
  doctorId            String?
  specialtyId         String?
  serviceId           String?
  kind                AssetKind
  key                 String
  path                String
  altText             String?
  usageNote           String?
  isActive            Boolean       @default(true)
  country             Country?      @relation(fields: [countryId], references: [id], onDelete: Cascade)
  doctor              Doctor?       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty           Specialty?    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  service             Service?      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  badges              Badge[]
  blogPostCovers      BlogPost[]    @relation("BlogPostCover")
  contentPageHeroes   ContentPage[] @relation("ContentPageHero")
  contentPageOgImages ContentPage[] @relation("ContentPageOg")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([kind, key])
}

model Badge {
  id        String   @id @default(cuid())
  countryId String
  assetId   String?
  label     String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsultationSetting {
  id                     String   @id @default(cuid())
  countryId              String   @unique
  enableGeneral          Boolean  @default(true)
  enableSpecialist       Boolean  @default(true)
  defaultDurationMinutes Int      @default(20)
  leadTimeMinutes        Int      @default(60)
  country                Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model BookingSetting {
  id                 String   @id @default(cuid())
  countryId          String   @unique
  bookingEnabled     Boolean  @default(true)
  requirePhone       Boolean  @default(true)
  requireDateOfBirth Boolean  @default(true)
  timezone           String   @default("UTC")
  country            Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  REFUNDED
  FAILED
}

model Appointment {
  id                        String                @id @default(cuid())
  userId                    String?
  countryCode               String
  consultationType          String
  fullName                  String
  email                     String
  phone                     String?
  /// Optional patient date of birth — captured when the country's
  /// BookingSetting.requireDateOfBirth is on. Stored as a Date so we
  /// can compute age + filter by ranges later.
  dateOfBirth               DateTime?
  notes                     String?
  consentAccepted           Boolean
  status                    String                @default("REQUEST_RECEIVED")
  // Optional link to the catalogue Service that was booked. Populated when
  // the booking form passes ?service=<slug>; null for free-text bookings.
  serviceId                 String?
  service                   Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  /// Optional HealthTest the patient picked at booking. Set when the
  /// booking form arrives with `?service=<healthTestSlug>` and the slug
  /// matches a HealthTest row. Symmetric with `serviceId` above.
  healthTestId              String?
  healthTest                HealthTest?           @relation(fields: [healthTestId], references: [id], onDelete: SetNull)
  /// Doctor assigned to take the call. Set by admin on the schedule form;
  /// the doctor's portal at /doctor scopes queries to `doctorId = self`.
  /// Optional because not every appointment has a doctor yet.
  doctorId                  String?
  doctor                    Doctor?               @relation("AppointmentDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  /// Concrete time slot the patient picked at booking. Populated when
  /// the booking form posts with `timeSlotId`; the booking handler
  /// atomically claims the slot (UPDATE…WHERE status='OPEN') so two
  /// patients can never grab the same one. Null = legacy flow (admin
  /// schedules the call manually later).
  timeSlotId                String?               @unique
  timeSlot                  DoctorTimeSlot?       @relation("AppointmentSlot", fields: [timeSlotId], references: [id], onDelete: SetNull)
  /// One Consultation row per Appointment — created on first save from
  /// the doctor portal, locked when signed.
  consultation              Consultation?
  /// Per-appointment lab / imaging / exam results the doctor logs.
  examResults               ExamResult[]
  /// Doctor ↔ admin notes for this appointment (NOT patient-visible —
  /// patient chat lives on `messages`).
  internalMessages          InternalMessage[]
  /// Form submissions tied to this appointment (intake, pre-consult,
  /// post-consult surveys).
  formSubmissions           FormSubmission[]
  /// First-party documents the doctor attaches to this appointment
  /// (PDFs, scans, photos). Stored in S3 under a doctor-scoped key
  /// prefix; admin doesn't auto-see them.
  documents                 AppointmentDocument[]
  /// Self-reference: when this appointment is a follow-up, points at
  /// the appointment the patient is following up FROM. Lets the
  /// workspace render a "Follow-up of …" badge and the patient
  /// history a continuous chain.
  followUpFromAppointmentId String?
  followUpFrom              Appointment?          @relation("AppointmentFollowUp", fields: [followUpFromAppointmentId], references: [id], onDelete: SetNull)
  followUps                 Appointment[]         @relation("AppointmentFollowUp")
  /// ONLINE (telemedicine, default) or IN_PERSON (in-clinic). Empty
  /// `meetingUrl` is the operational signal for IN_PERSON today.
  consultationMode          ConsultationMode      @default(ONLINE)
  // Payment lifecycle. UNPAID = free or pending-Stripe.
  paymentStatus             PaymentStatus         @default(UNPAID)
  // Stripe identifiers. Null until a Checkout Session is created.
  stripeSessionId           String?               @unique
  stripePaymentIntentId     String?               @unique
  amountCents               Int?
  currencyCode              String?
  paidAt                    DateTime?
  // Scheduled call time + Google Meet (or any video) URL. Admin sets these
  // once a slot has been agreed; patient sees them on /account/bookings and
  // receives a SendGrid email with the link.
  scheduledAt               DateTime?
  meetingUrl                String?
  // Reminder job marks this once it has emailed the patient ~24h before
  // scheduledAt, so re-runs don't double-send. Null means "not sent yet".
  reminderSentAt            DateTime?
  // Same idea but for the in-portal "you have an appointment tomorrow"
  // notification fan-out to the assigned doctor. Tracked separately so
  // the patient-email path and the doctor-notification path can diverge.
  doctorReminderSentAt      DateTime?
  user                      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  payments                  Payment[]
  messages                  Message[]
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
}

/// Lightweight chat thread for the patient ↔ admin pre-consult conversation.
/// Newsletter signups from the footer form. Patient supplies email + the
/// country/locale context they were on; admin can export the list.
model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  countryCode    String?
  locale         String?
  source         String?
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([createdAt])
}

/// One thread per Appointment. Polling-based (no WebSocket layer); when
/// volume justifies it we can swap to Pusher / Soketi without UI changes.
enum MessageAuthorRole {
  PATIENT
  ADMIN
}

model Message {
  id            String            @id @default(cuid())
  appointmentId String
  appointment   Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  authorRole    MessageAuthorRole
  authorUserId  String? // null for the patient guest-booking path
  body          String
  readByPatient Boolean           @default(false)
  readByAdmin   Boolean           @default(false)
  createdAt     DateTime          @default(now())

  @@index([appointmentId, createdAt])
}

/// Append-only ledger of Stripe events per Appointment. One row per webhook
/// `payment_intent.{created,succeeded,failed}` we accept. Makes the audit
/// trail explicit even when an appointment ends up REFUNDED later.
model Payment {
  id                    String        @id @default(cuid())
  appointmentId         String
  appointment           Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  stripeEventId         String        @unique
  stripeSessionId       String?
  stripePaymentIntentId String?
  status                PaymentStatus
  amountCents           Int
  currencyCode          String
  rawEventType          String
  rawPayload            Json
  createdAt             DateTime      @default(now())

  @@index([appointmentId])
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  fullName                String
  phone                   String?
  role                    UserRole                 @default(PATIENT)
  emailVerifiedAt         DateTime?
  isActive                Boolean                  @default(true)
  /// Set when role=DOCTOR — links the login account to the Doctor
  /// profile that shows on the public site. Admin assigns this from
  /// the doctor edit page. One-to-one.
  doctorId                String?                  @unique
  doctorProfile           Doctor?                  @relation("DoctorUserLink", fields: [doctorId], references: [id], onDelete: SetNull)
  appointments            Appointment[]
  resetTokens             PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  /// Internal (doctor ↔ admin) messages this user authored. Patient
  /// messages live on `Message.authorUserId` which is unrelated to
  /// this relation name.
  internalMessages        InternalMessage[]        @relation("InternalMessageAuthor")
  /// Doctor portal notifications routed to this user.
  notifications           Notification[]
  /// Share links this user created (signed consultation URLs etc.).
  shareLinks              ShareLink[]              @relation("ShareLinkAuthor")
  /// Patient-side: form submissions associated to this user (when the
  /// patient is signed-in at submit time). Guest submissions don't
  /// reference a user.
  formSubmissions         FormSubmission[]
  /// Audit-log rows authored by this user (consult signs, message
  /// posts, share-link mints…). actor=null entries are SYSTEM events.
  auditEvents             AuditLog[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  /**
   * Distinguishes a doctor-invite token (7-day TTL, on-consume auto
   * sign-in) from a regular forgot-password token (1-hour TTL, no
   * auto sign-in). The consume path validates the caller's intent
   * against this flag so a stolen reset token can't be replayed with
   * `?invite=1` to grant a session.
   */
  isInvite  Boolean   @default(false)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
}

model BlogPost {
  id                  String        @id @default(cuid())
  countryId           String?
  slug                String
  title               String
  excerpt             String?
  body                String
  status              PublishStatus @default(DRAFT)
  locale              LocaleCode
  category            String?
  authorDisplayName   String?
  reviewerDisplayName String?
  coverAssetId        String?
  seoTitle            String?
  seoDescription      String?
  publishedAt         DateTime?
  lastReviewedAt      DateTime?
  editorialChecklist  Json?
  isActive            Boolean       @default(true)
  country             Country?      @relation(fields: [countryId], references: [id], onDelete: SetNull)
  coverAsset          Asset?        @relation("BlogPostCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([slug, locale, countryId])
}

model Faq {
  id           String     @id @default(cuid())
  countryId    String?
  question     String
  answer       String
  locale       LocaleCode
  category     String?
  placementKey String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  country      Country?   @relation(fields: [countryId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ContentPage {
  id                 String        @id @default(cuid())
  countryId          String
  pageKey            PageKey
  locale             LocaleCode
  status             PublishStatus @default(DRAFT)
  title              String
  body               String
  heroTitle          String?
  heroSubtitle       String?
  heroImageAssetId   String?
  heroImagePath      String?
  ctaLabel           String?
  ctaHref            String?
  ogImageAssetId     String?
  ogImagePath        String?
  seoTitle           String?
  seoDescription     String?
  lastReviewedAt     DateTime?
  editorialChecklist Json?
  isActive           Boolean       @default(true)
  country            Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  heroImage          Asset?        @relation("ContentPageHero", fields: [heroImageAssetId], references: [id], onDelete: SetNull)
  ogImage            Asset?        @relation("ContentPageOg", fields: [ogImageAssetId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([countryId, pageKey, locale])
}

enum ReviewProvider {
  TRUSTPILOT
  GOOGLE
  DOCTIFY
  INTERNAL
}

/**
 * Cached external reviews + aggregate snapshots. The admin Settings page
 * stores the configuration IDs separately (via `Setting` rows), but the
 * per-provider aggregate (rating + count) lives here so the public
 * ReviewBadge and `AggregateRating` JSON-LD can read a single row per
 * (countryId?, provider) combination.
 * When live API integrations land later (Trustpilot Business API,
 * Google Place Details, Doctify), they'll write to this table.
 */
model Review {
  id          String         @id @default(cuid())
  countryId   String?
  provider    ReviewProvider
  externalId  String?
  rating      Int
  title       String?
  body        String?
  authorName  String?
  sourceUrl   String?
  verifiedAt  DateTime?
  isApproved  Boolean        @default(true)
  publishedAt DateTime?
  country     Country?       @relation(fields: [countryId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([provider, externalId])
  @@index([countryId, provider])
}

/**
 * Site-wide key/value config the super-admin can edit without a deploy.
 * Used for review provider IDs, current aggregate ratings, support
 * contact info, and other settings that don't justify their own table.
 * Values are JSON so structured data (e.g. aggregate snapshots) fits
 * alongside plain strings.
 * Known keys (Phase 4):
 * review.trustpilot.businessUnitId   string
 * review.trustpilot.aggregate        { rating: number, count: number, updatedAt: iso8601 }
 * review.google.placeId              string
 * review.google.aggregate            { rating: number, count: number, updatedAt: iso8601 }
 * review.doctify.clinicId            string
 * review.doctify.aggregate           { rating: number, count: number, updatedAt: iso8601 }
 * review.primaryProvider             "TRUSTPILOT" | "GOOGLE" | "DOCTIFY"
 */
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/// Clinical SOAP note bound to a single Appointment. Created lazily —
/// the row only materialises the first time the doctor saves something
/// from the portal. Locks on SIGN; further edits would require an
/// amendment row (out of scope today).
model Consultation {
  id             String                @id @default(cuid())
  appointmentId  String                @unique
  doctorId       String
  chiefComplaint String?
  /// SOAP: Subjective — patient-reported history.
  subjective     String?
  /// SOAP: Objective — observable findings, vitals, exam.
  objective      String?
  /// SOAP: Assessment — clinical impression, diagnoses.
  assessment     String?
  /// SOAP: Plan — prescriptions, follow-up, referrals.
  plan           String?
  status         ConsultationStatus    @default(DRAFT)
  signedAt       DateTime?
  appointment    Appointment           @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor         Doctor                @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  /// Per-consult services-rendered line items.
  servicesUsed   ConsultationService[]
  /// Share links pointing at this consultation (signed referral URLs).
  shareLinks     ShareLink[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([doctorId, status])
}

/// Per-appointment lab / imaging / test order or result the doctor
/// records. The same row covers two lifecycle states:
///   REQUESTED — doctor has ordered the test, result not in yet
///   COMPLETED — result recorded (notes / externalUrl populated)
/// `externalUrl` links to a partner lab portal; first-party PDFs live
/// on `AppointmentDocument` so clinical doc storage stays in one place.
model ExamResult {
  id            String      @id @default(cuid())
  appointmentId String
  doctorId      String
  testName      String
  status        ExamStatus  @default(COMPLETED)
  performedAt   DateTime?
  notes         String?
  externalUrl   String?
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor        Doctor      @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([appointmentId, createdAt])
  @@index([doctorId, createdAt])
  @@index([appointmentId, status])
}

/// Doctor ↔ admin per-appointment note thread. Distinct from the
/// patient-facing `Message` model — patients can never see these.
model InternalMessage {
  id            String                    @id @default(cuid())
  appointmentId String
  authorUserId  String
  authorRole    InternalMessageAuthorRole
  body          String
  appointment   Appointment               @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  author        User                      @relation("InternalMessageAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  createdAt     DateTime                  @default(now())

  @@index([appointmentId, createdAt])
}

/// Per-consultation services-rendered line item. The doctor records
/// which catalogue services they performed during the consult; admin
/// uses these rows for invoicing. `serviceId` links to the Service
/// catalogue row when one matches; `customLabel` carries free-text for
/// off-catalogue procedures.
model ConsultationService {
  id             String       @id @default(cuid())
  consultationId String
  serviceId      String?
  customLabel    String?
  quantity       Int          @default(1)
  unitPriceCents Int?
  currencyCode   String?
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  service        Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([consultationId])
}

/// Reusable form template (intake, pre-consult survey, post-consult
/// feedback). `fields` is a JSON array of `{ key, label, type, required,
/// options? }`. Validated server-side at submit time.
///
/// `doctorId = null` means an admin-managed shared template available to
/// every doctor; a set `doctorId` scopes the template to one practice.
model FormTemplate {
  id          String           @id @default(cuid())
  doctorId    String?
  title       String
  description String?
  fields      Json
  isActive    Boolean          @default(true)
  doctor      Doctor?          @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  submissions FormSubmission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([doctorId, isActive])
}

/// One submission of a FormTemplate. `answers` is a JSON array of
/// `{ key, value }`. `appointmentId` ties it to a specific encounter;
/// `patientUserId` records the signed-in patient who filled it (null
/// for guest submissions or when the doctor logs answers on the
/// patient's behalf).
model FormSubmission {
  id            String       @id @default(cuid())
  templateId    String
  appointmentId String?
  patientUserId String?
  answers       Json
  submittedAt   DateTime     @default(now())
  template      FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patientUser   User?        @relation(fields: [patientUserId], references: [id], onDelete: SetNull)

  @@index([appointmentId, submittedAt])
  @@index([templateId, submittedAt])
}

/// Doctor portal notification. Polling-based today; the bell on the
/// doctor portal fetches unread count every minute. `payload` carries
/// per-type context (e.g. `{ appointmentId, snippet }`).
model Notification {
  id              String           @id @default(cuid())
  recipientUserId String
  type            NotificationType
  payload         Json
  readAt          DateTime?
  recipient       User             @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())

  @@index([recipientUserId, readAt])
  @@index([recipientUserId, createdAt])
}

/// Signed share link. Doctor generates one for a signed consultation
/// to hand off to a referring colleague; expires after the chosen
/// window (default 7 days). The token is the URL-safe random; never
/// reuse the row id for sharing.
model ShareLink {
  id              String         @id @default(cuid())
  scope           ShareLinkScope
  consultationId  String?
  token           String         @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  createdByUserId String
  consultation    Consultation?  @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  createdBy       User           @relation("ShareLinkAuthor", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime       @default(now())

  @@index([consultationId])
}

/// Append-only audit trail for clinical + collaboration mutations.
/// Reads are admin-only via `/admin/audit-log`. Writers across the
/// codebase use the `recordAudit` helper instead of poking the table
/// directly so failures stay quiet (never block the underlying
/// mutation).
///
/// `entityType` carries the model name (`"Consultation"`,
/// `"ExamResult"`, `"InternalMessage"`, `"ShareLink"`,
/// `"FormSubmission"`, `"ConsultationService"`); `entityId` is the
/// affected row id. `metadata` JSON is free-form — typical keys are
/// `appointmentId`, `snippet`, `consultationId`.
model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?
  /// Snapshot of the actor's role at event time. Useful when a User
  /// later gets demoted (e.g. doctor de-linked) and we still want to
  /// see they signed a consult while they were a doctor.
  actorRole   String?
  action      AuditAction
  entityType  String
  entityId    String
  metadata    Json?
  ipAddress   String?
  actorUser   User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

/// First-party clinical documents the doctor attaches to an
/// appointment (PDFs, scans, photos). Stored in S3 under a
/// doctor-scoped key prefix. Kept separate from `Asset` (which is
/// marketing-side, admin-managed, and publicly addressable) so the
/// access surface is unambiguous.
model AppointmentDocument {
  id            String      @id @default(cuid())
  appointmentId String
  doctorId      String
  label         String
  storageKey    String
  mimetype      String
  byteSize      Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor        Doctor      @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())

  @@index([appointmentId, createdAt])
  @@index([doctorId, createdAt])
}
