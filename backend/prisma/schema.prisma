// Account model (planning): there is no User/UserRole in this schema yet.
// Future auth on THIS website should be PATIENT | ADMIN only.
// The Doctor model below is public marketing/directory data — not a login identity.
// Clinical doctor accounts belong to a separate doctor portal (deferred, out of scope).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LocaleCode {
  EN
  PT
  ES
  CS
  RO
  DE
}

enum AssetKind {
  IMAGE
  ICON
  LOGO
  BADGE
  SOCIAL
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

enum ServiceKind {
  GENERAL
  SPECIALIST
  PRESCRIPTION
  HEALTH_TEST
  HOME_DELIVERY
}

enum UserRole {
  PATIENT
  ADMIN
}

model Currency {
  id        String   @id @default(cuid())
  code      String   @unique
  symbol    String
  decimals  Int      @default(2)
  countries Country[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Country {
  id                        String                @id @default(cuid())
  code                      String                @unique
  name                      String
  slug                      String                @unique
  legacyHomePath            String                @unique
  teamPath                  String                @unique
  generalConsultationPath   String                @unique
  specialistConsultationPath String               @unique
  defaultLocale             LocaleCode            @default(EN)
  currencyId                String
  currency                  Currency              @relation(fields: [currencyId], references: [id])
  isActive                  Boolean               @default(true)
  countryLocales            CountryLocale[]
  domains                   CountryDomain[]
  clinics                   Clinic[]
  doctors                   Doctor[]
  specialties               Specialty[]
  services                  Service[]
  pricingPlans              PricingPlan[]
  assets                    Asset[]
  blogPosts                 BlogPost[]
  faqs                      Faq[]
  contentPages              ContentPage[]
  badges                    Badge[]
  consultationSetting       ConsultationSetting?
  bookingSetting            BookingSetting?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
}

model CountryLocale {
  id        String     @id @default(cuid())
  countryId String
  locale    LocaleCode
  isDefault Boolean    @default(false)
  country   Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, locale])
}

model CountryDomain {
  id        String   @id @default(cuid())
  countryId String
  domain    String   @unique
  isPrimary Boolean  @default(false)
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, isPrimary])
}

model Clinic {
  id        String   @id @default(cuid())
  countryId String
  name      String
  slug      String
  city      String?
  active    Boolean  @default(true)
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, slug])
}

/// Public website profile (directory/CMS). Admins may edit these rows as content.
/// Not an authenticated user: no doctor dashboard or portal login in this application.
model Doctor {
  id         String           @id @default(cuid())
  countryId  String
  slug       String
  fullName   String
  title      String
  bio        String?
  seoTitle   String?
  seoDescription String?
  imcRegistration String?
  medicalRegistrationUrl String?
  qualifications  String[]
  whatsappNumber  String?
  languages       String[]
  editorialChecklist Json?
  active     Boolean          @default(true)
  country    Country          @relation(fields: [countryId], references: [id], onDelete: Cascade)
  specialties DoctorSpecialty[]
  assets     Asset[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([countryId, slug])
}

model Specialty {
  id               String           @id @default(cuid())
  countryId        String
  slug             String
  name             String
  cardSummary      String?
  cardThemeColor   String?
  sortOrder        Int              @default(0)
  primaryServiceId String?
  active           Boolean          @default(true)
  country          Country          @relation(fields: [countryId], references: [id], onDelete: Cascade)
  doctors          DoctorSpecialty[]
  services         Service[]        @relation("ServiceSpecialty")
  primaryService   Service?         @relation("SpecialtyPrimaryService", fields: [primaryServiceId], references: [id], onDelete: SetNull)
  assets           Asset[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([countryId, slug])
}

model DoctorSpecialty {
  id          String    @id @default(cuid())
  doctorId    String
  specialtyId String
  doctor      Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty   Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@unique([doctorId, specialtyId])
}

model Service {
  id                  String      @id @default(cuid())
  countryId           String
  specialtyId         String?
  kind                ServiceKind @default(GENERAL)
  slug                String
  name                String
  summary             String?
  seoTitle            String?
  seoDescription      String?
  heroTitle           String?
  heroDescription     String?
  detailBody          String?
  ctaLabel            String?
  legacyPath          String?
  sortOrder           Int         @default(0)
  durationMinutes     Int?
  basePriceCents      Int?
  currencyCode        String?
  editorialChecklist  Json?
  isActive            Boolean     @default(true)
  consultationSetting Json?
  bookingSetting      Json?
  country             Country     @relation(fields: [countryId], references: [id], onDelete: Cascade)
  specialty           Specialty?  @relation("ServiceSpecialty", fields: [specialtyId], references: [id])
  primaryForSpecialties Specialty[] @relation("SpecialtyPrimaryService")
  assets              Asset[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@unique([countryId, slug])
}

model PricingPlan {
  id          String   @id @default(cuid())
  countryId   String
  slug        String
  name        String
  description String?
  priceCents  Int
  currencyCode String
  interval    String
  isActive    Boolean  @default(true)
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([countryId, slug])
}

model Asset {
  id            String      @id @default(cuid())
  countryId     String?
  doctorId      String?
  specialtyId   String?
  serviceId     String?
  kind          AssetKind
  key           String
  path          String
  altText       String?
  usageNote     String?
  isActive      Boolean     @default(true)
  country       Country?    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  doctor        Doctor?     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  specialty     Specialty?  @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  service       Service?    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  badges        Badge[]
  blogPostCovers BlogPost[] @relation("BlogPostCover")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([kind, key])
}

model Badge {
  id         String   @id @default(cuid())
  countryId  String
  assetId    String?
  label      String
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  country    Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  asset      Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ConsultationSetting {
  id                     String   @id @default(cuid())
  countryId              String   @unique
  enableGeneral          Boolean  @default(true)
  enableSpecialist       Boolean  @default(true)
  defaultDurationMinutes Int      @default(20)
  leadTimeMinutes        Int      @default(60)
  country                Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model BookingSetting {
  id                  String   @id @default(cuid())
  countryId           String   @unique
  bookingEnabled      Boolean  @default(true)
  requirePhone        Boolean  @default(true)
  requireDateOfBirth  Boolean  @default(true)
  timezone            String   @default("UTC")
  country             Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Appointment {
  id                 String   @id @default(cuid())
  userId             String?
  countryCode        String
  consultationType   String
  fullName           String
  email              String
  phone              String?
  notes              String?
  consentAccepted    Boolean
  status             String   @default("REQUEST_RECEIVED")
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  passwordHash      String
  fullName          String
  phone             String?
  role              UserRole             @default(PATIENT)
  emailVerifiedAt   DateTime?
  isActive          Boolean              @default(true)
  appointments      Appointment[]
  resetTokens       PasswordResetToken[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model BlogPost {
  id                String       @id @default(cuid())
  countryId         String?
  slug              String
  title             String
  excerpt           String?
  body              String
  status            PublishStatus @default(DRAFT)
  locale            LocaleCode
  category          String?
  authorDisplayName String?
  reviewerDisplayName String?
  coverAssetId      String?
  seoTitle          String?
  seoDescription    String?
  publishedAt       DateTime?
  lastReviewedAt    DateTime?
  editorialChecklist Json?
  isActive          Boolean      @default(true)
  country           Country?     @relation(fields: [countryId], references: [id], onDelete: SetNull)
  coverAsset        Asset?       @relation("BlogPostCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([slug, locale, countryId])
}

model Faq {
  id           String     @id @default(cuid())
  countryId    String?
  question     String
  answer       String
  locale       LocaleCode
  category     String?
  placementKey String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  country      Country?   @relation(fields: [countryId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ContentPage {
  id             String        @id @default(cuid())
  countryId      String?
  pageKey        String
  title          String
  body           String
  locale         LocaleCode
  status         PublishStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  lastReviewedAt DateTime?
  editorialChecklist Json?
  isActive       Boolean       @default(true)
  country        Country?      @relation(fields: [countryId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([pageKey, locale, countryId])
}
