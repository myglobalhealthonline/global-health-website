{
  "name": "backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./auth/admin-access-evaluator": "./lib/auth/admin-access-evaluator.ts",
    "./auth/session": "./lib/auth/session.ts",
    "./audit/log": "./lib/audit/log.ts",
    "./appointments/status-transitions": "./lib/appointments/status-transitions.ts",
    "./storage/media-key": "./lib/storage/media-key.ts",
    "./shared/db-errors": "./lib/shared/db-errors.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test lib/auth/admin-auth.test.ts lib/appointments/status-transitions.test.ts lib/storage/media-key.test.ts lib/shared/db-errors.classify.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1043.0",
    "@aws-sdk/s3-request-presigner": "^3.1043.0",
    "dotenv": "^17.4.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "jose": "^5.9.6",
    "pg": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
