{
    "name": "backend",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "typecheck": "tsc --noEmit",
        "test": "node --import tsx --test src/modules/appointments/appointment-status-transitions.test.ts src/routes/account-appointments.route.test.ts src/validations/account-appointments.schema.test.ts src/modules/countries/admin-countries.schema.test.ts src/modules/services/admin-services.schema.test.ts src/modules/doctors/admin-doctors.schema.test.ts src/modules/pricing/admin-pricing.schema.test.ts src/modules/assets/admin-assets.schema.test.ts src/modules/blog/admin-blog-posts.schema.test.ts src/modules/faqs/admin-faqs.schema.test.ts src/modules/content-pages/admin-content-pages.schema.test.ts src/modules/auth/auth.schema.test.ts src/modules/shared/db-errors.classify.test.ts",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:seed": "tsx prisma/seed.ts",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bcryptjs": "^3.0.3",
        "dotenv": "^17.4.2",
        "fastify": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.20.0",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0",
        "tsx": "^4.21.0",
        "typescript": "^5"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}
