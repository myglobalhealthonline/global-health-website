{
  "name": "global-health-platform",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build": "pnpm --filter frontend build && pnpm --filter backend build",
    "typecheck": "pnpm --filter frontend typecheck && pnpm --filter backend typecheck",
    "lint": "pnpm --filter frontend lint",
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:deploy": "pnpm --filter backend db:deploy",
    "db:seed": "pnpm --filter backend db:seed",
    "db:studio": "pnpm --filter backend db:studio"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
