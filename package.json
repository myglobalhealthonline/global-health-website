{
  "name": "global-health-platform",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @gh/web dev",
    "build": "pnpm --filter @gh/web build",
    "start": "pnpm --filter @gh/web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter @gh/web lint",
    "test": "pnpm --filter @gh/lib test",
    "db:generate": "pnpm --filter @gh/db db:generate",
    "db:migrate": "pnpm --filter @gh/db db:migrate",
    "db:deploy": "pnpm --filter @gh/db db:deploy",
    "db:reset": "pnpm --filter @gh/db db:reset",
    "db:seed": "pnpm --filter @gh/db db:seed",
    "db:studio": "pnpm --filter @gh/db db:studio"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
